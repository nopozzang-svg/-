{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron-daily",
      "schedule": "10 23 * * *"
    },
    {
      "path": "/api/cron-intl",
      "schedule": "*/10 22,23,0,1 * * *"
    }
  ]
}
