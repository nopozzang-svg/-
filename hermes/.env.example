# hermes/.env — 실제 값 채운 뒤 hermes/.env 로 저장 (이 example 파일만 git에 올라감)
# 실행:  node --env-file=hermes/.env hermes/ingest-nas.mjs

NAS_URL=https://seilcorp.synology.me:5001
NAS_USER=여기에_아이디
NAS_PASS=여기에_비밀번호
NAS_INSECURE=1                    # 시놀로지 인증서 TLS 오류 시 1, 아니면 삭제

# 텔레그램 '일보 미도착' 알림용 (아침 체크 모드에서 사용)
#   1) @BotFather 로 봇 생성 → 토큰
#   2) 봇에게 아무 메시지 보낸 뒤: node --env-file=hermes/.env hermes/telegram-chatid.mjs → chat_id
TELEGRAM_BOT_TOKEN=여기에_봇토큰
TELEGRAM_CHAT_ID=여기에_chat_id

# 아래는 미설정 시 기본값 사용 (보통 안 건드려도 됨)
# NAS_ROOT=/seil_share/주유소 운영 (소매)   # 대상 주유소 폴더들이 들어있는 상위 폴더
# NAS_YEARS=26                              # 처리 연도(2자리). 미설정 시 올해만. 백필 예: 24,25,26

# SUPABASE_URL=
# SUPABASE_ANON_KEY=
